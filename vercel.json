{
    "redirects": [
      {
        "source": "/(lunch|dinner|categories|print)",
        "has": [
          {
            "type": "cookie",
            "key": "session"
          }
        ],
        "destination": "/login",
        "statusCode": 302
      },
      {
        "source": "/api/(.*)",
        "destination": "/api/:1",
        "statusCode": 200
      },
      {
        "source": "/(.*)",
        "destination": "/",
        "statusCode": 200
      }
    ]
}